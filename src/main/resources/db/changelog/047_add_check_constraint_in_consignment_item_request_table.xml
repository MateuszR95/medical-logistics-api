<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.2.xsd">

    <changeSet id="047_add_check_constraint_in_consignment_item_request_table" author="mrojek">
        <sql>
            ALTER TABLE consignment_item_request
                ADD CONSTRAINT ck_cir_customer_required_by_type
                    CHECK ( (type = 'SET_REPLENISHMENT') OR (customer_id IS NOT NULL) );
        </sql>
    </changeSet>

</databaseChangeLog>