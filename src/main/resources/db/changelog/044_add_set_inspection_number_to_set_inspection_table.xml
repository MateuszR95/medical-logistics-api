<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.2.xsd">

    <changeSet id="044_add_set_inspection_number_to_set_inspection_table" author="mrojek">

        <addColumn tableName="set_inspection">
            <column name="set_inspection_number" type="varchar(80)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <addNotNullConstraint tableName="set_inspection"
                              columnName="set_inspection_number"
                              columnDataType="varchar(80)"/>

        <addUniqueConstraint tableName="set_inspection"
                             columnNames="set_inspection_number"
                             constraintName="uq_si_inspection_number"/>

    </changeSet>

</databaseChangeLog>